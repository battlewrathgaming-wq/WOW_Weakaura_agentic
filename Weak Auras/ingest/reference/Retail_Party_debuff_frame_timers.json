    "init": {
     "custom": "aura_env.shorten = function(unit, num)\n    local classFilename = select(2, UnitClass(unit))\n    if classFilename then\n        local color = GetClassColorObj(classFilename)\n        if color then\n            local text = WA_Utf8Sub(UnitName(unit), num)\n            if text then\n                return color:WrapTextInColorCode(text)\n            end\n        end\n    end\nend\n\naura_env.roleicon = function(name)\n    local role = UnitGroupRolesAssigned(name)\n    if role ~= \"NONE\" then\n        return CreateTextureMarkup([[Interface\\LFGFrame\\UI-LFG-ICON-ROLES]], 256, 256, 0, 0, GetTexCoordsForRole(UnitGroupRolesAssigned(name)))\n    else\n        return \"\"\n    end\nend",
