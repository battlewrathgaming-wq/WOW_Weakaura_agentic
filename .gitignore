__pycache__/
*.pyc
.fuse_manifest.json
git_push_log.txt

# project_index: regenerable local index data, not source content.
# search_index.json in particular gets rewritten (and can be several MB)
# on every scan - committing it would bloat history with noisy diffs for
# zero real information (it's fully rebuildable from the project files).
Weak Auras/Tools/project_index/index.json
Weak Auras/Tools/project_index/search_index.json
Weak Auras/Tools/project_index/activity.log

# .tools/: contained dev binaries (LuaBinaries 5.1.5 for wa_lua_verify), not
# source - platform-specific, rebuildable by re-downloading. Never commit.
.tools/

# derived corpus/library artifacts - regenerable from the live SavedVariables
# via aura_scrape.py / blocks_db.py; can be large / binary. Not source.
Outputs/aura_corpus/

# plane/ assembler output - regenerable from the BOM + parts via assemble.py,
# and the import string re-mints a fresh uid each run (would churn). Source is
# the BOM/parts/scripts, not this generated table/string.
Weak Auras/plane/out/

# ingest/inbox/ - transient drop zone for import strings awaiting processing.
# ingest.py moves them to processed/ (tracked) + writes reference/ (tracked);
# the inbox itself is local staging, not content.
Weak Auras/ingest/inbox/

# ability_inventory/reference.html - the community HTML reference (~1.5MB), regenerated
# wholesale from the tracked out/*.json via build_reference.py on every rebuild. Track the
# DATA (out/*.json, incl. captures.json - the game scrape, not reproducible from the repo);
# regenerate this deliverable on demand. NOTE: ability_inventory/out/ is TRACKED (it holds
# the scraped+consolidated dataset), unlike plane/out/ which is pure regenerable build output.
Weak Auras/ability_inventory/reference.html

# export/ + the share zip - transient handoff staging (assembled copies of tracked data for
# sharing, per SHARING.md). Regenerable via the copy step; not source, not preserved. Never commit.
export/
coa_data_share.zip

# Launcher.lnk / Addons Bench.lnk - the pinnable taskbar shortcuts to the two menu.bats;
# machine-specific (hold absolute paths), regenerated per machine. Not source.
Launcher.lnk
addons/Addons Bench.lnk

# /runtime/ - the service-runner's transient queue/receipts/processed (Claude queues calls,
# the runner executes + receipts back). Ephemeral IPC, not source. Anchored to the repo root:
# the unanchored form silently swallowed addons/maps/census/runtime/ (caught 2026-07-15).
/runtime/

# Outputs/lane_index.json - the FIRST-CUT behavioural lane classification (grab-by-class,
# traceable), regenerated on demand via `py Scripts/classify_lanes.py --emit` from
# dependencies/coa_spells.json + the inventory. Cheap + provisional (lane names not yet
# hardened -> would churn). Regenerate, don't track. Source is classify_lanes.py + spell_enums.py.
Outputs/lane_index.json

# addons/landing/raw/ - verbatim clones of the flushed SavedVariables file: the local audit
# receipt behind each parsed record in landing/records/ (which IS tracked - captures aren't
# reproducible from the repo). Same class as ingest/inbox: local receipts, multi-MB per
# capture; the parsed record is the keep, the raw clone is the on-disk audit trail.
addons/landing/raw/

# Outputs/client_interface/ - extracted study copy of the client's own Interface code
# (Ascension_* addons / FrameXML / SharedXML / LibraryXML out of Data/patch-B.MPQ), regenerable
# via addons/tools/extract_interface.py. Third-party client code, not ours to track; census
# maps derived FROM it are tracked (addons/maps/) and cite the manifest's source sha256.
Outputs/client_interface/

# Outputs/spell_dbc/ - the full Spell.dbc manifest dump (~163MB, 237k spells), regenerable
# from the live client MPQ via Scripts/extract_spell_dbc.py. Pure "store all" scratch: the
# whole dir is regenerable and ignored. The COA-relevant FILTERED subset is written to the
# tracked dependencies/ folder instead (see filter_coa_spells.py), so nothing here is kept.
Outputs/spell_dbc/
